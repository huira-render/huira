# Set default behavior to automatically normalize line endings
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to LF line endings on checkout to prevent clang-format CI failures
*.c text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.cc text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.hxx text eol=lf
*.cmake text eol=lf
*.txt text
*.md text
*.sh text eol=lf
*.bat text eol=crlf

# Declare files that will always have LF line endings on checkout
Makefile text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.so binary
*.dll binary
*.exe binary
*.a binary
*.lib binary
