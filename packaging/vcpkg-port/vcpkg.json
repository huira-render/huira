{
  "name": "huira",
  "version": "0.9.5",
  "description": "A library for space rendering, LiDAR simulation, and solar radiation pressure modeling.",
  "homepage": "https://github.com/huira-render/huira",
  "documentation": "https://docs.huira.space",
  "license": "MIT",
  "supports": "!android & !uwp & !xbox",
  "dependencies": [
    {
      "name": "assimp",
      "features": [
        "draco"
      ]
    },
    "cfitsio",
    "cspice",
    {
      "name": "embree",
      "default-features": false,
      "features": [
        "geometry-instance",
        "geometry-point",
        "geometry-triangle",
        "geometry-user",
        "ray-mask",
        "tasking-tbb"
      ]
    },
    "fftw3",
    "glm",
    "libjpeg-turbo",
    "libpng",
    "tbb",
    "tiff",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "tools": {
      "description": "Build huira command line tools",
      "dependencies": [
        {
          "name": "curl",
          "default-features": false
        },
        "indicators"
      ]
    },
    "tests": {
        "description": "Build huira tests",
        "dependencies": [
          "catch2"
        ]
    }
  }
}
