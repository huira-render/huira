set(_manifest "@CMAKE_BINARY_DIR@/install_manifest.txt")

if(EXISTS "${_manifest}")
    message(STATUS "Found previous huira install manifest, cleaning stale files...")
    file(READ "${_manifest}" _files)
    string(REGEX REPLACE "\n" ";" _files "${_files}")
    list(FILTER _files EXCLUDE REGEX "^$")
    foreach(_file IN LISTS _files)
        if(EXISTS "${_file}" OR IS_SYMLINK "${_file}")
            message(STATUS "  Removing: ${_file}")
            file(REMOVE "${_file}")
        endif()
    endforeach()
    message(STATUS "Previous huira installation cleaned.")
endif()