@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Add installed find modules to module path
list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

# PACKAGE_PREFIX_DIR is set by @PACKAGE_INIT@ and is always the correct
# prefix, regardless of whether the config file lives in lib/cmake/huira
# (normal install) or share/huira (vcpkg after config fixup).
set(HUIRA_DATA_DIR "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_DATADIR@/huira/data")

# Find dependencies (in order):
find_dependency(assimp CONFIG)

find_dependency(CFITSIO)

find_dependency(CSPICE)

find_dependency(embree CONFIG)

find_dependency(FFTW3f)

find_dependency(GDAL)

find_dependency(glm CONFIG)
if(NOT glm_FOUND)
    find_path(GLM_INCLUDE_DIR glm/glm.hpp REQUIRED)
    add_library(glm::glm INTERFACE IMPORTED)
    target_include_directories(glm::glm INTERFACE ${GLM_INCLUDE_DIR})
endif()

find_dependency(libjpeg-turbo CONFIG)
if(TARGET libjpeg-turbo::turbojpeg)
    set(TURBOJPEG_TARGET libjpeg-turbo::turbojpeg)
else()
    set(TURBOJPEG_TARGET libjpeg-turbo::turbojpeg-static)
endif()

find_dependency(PNG)

find_dependency(TBB CONFIG)

find_dependency(TIFF)

include("${CMAKE_CURRENT_LIST_DIR}/huiraTargets.cmake")

# Add the data dir definition to the imported target
set_property(TARGET huira::huira APPEND PROPERTY
    INTERFACE_COMPILE_DEFINITIONS "HUIRA_DEFAULT_DATA_DIR=\"${HUIRA_DATA_DIR}\""
)

check_required_components(huira)
